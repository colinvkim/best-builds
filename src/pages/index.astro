---
import "../styles/global.css";
import { Font } from "astro:assets";
import {
  NativeSelect,
  NativeSelectOptGroup,
  NativeSelectOption,
} from "@/components/ui/native-select";
import {
  InputGroup,
  InputGroupAddon,
  InputGroupButton,
  InputGroupInput,
  InputGroupText,
  InputGroupTextarea,
} from "@/components/ui/input-group";
import { Kbd } from "@/components/ui/kbd";
import { Search } from "lucide-react";
import BrawlerCard from "../components/BrawlerCard.astro";
import rawBrawlers from "../data/brawlers.json";
import {
  normalizeBrawlers,
  RARITY_ORDER,
  RARITY_STYLES,
} from "../lib/brawlers";

const brawlers = normalizeBrawlers(rawBrawlers).sort((left, right) => {
  if (left.rarityRank !== right.rarityRank) {
    return left.rarityRank - right.rarityRank;
  }

  return left.brawlerName.localeCompare(right.brawlerName);
});

const rarityCount = new Map<string, number>();

for (const brawler of brawlers) {
  rarityCount.set(brawler.rarity, (rarityCount.get(brawler.rarity) ?? 0) + 1);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Best Builds for Every Brawler</title>
    <meta
      name="description"
      content="Fast, searchable Brawl Stars best builds powered by a local JSON file and Brawlify CDN icons."
    />
    <link rel="preconnect" href="https://cdn.brawlify.com" crossorigin />
    <Font cssVariable="--font-inter" />
  </head>

  <body>
    <main class="page-shell">
      <section class="hero-panel" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="hero-kicker">Brawl Stars Build Index</p>
          <h1 id="page-title" class="hero-title">
            Best setup for every brawler, sorted for speed.
          </h1>
          <p class="hero-copy-text">
            Quickly discover the best builds of brawlers. The UI stays simple on
            purpose: fast search, predictable sorting, no animation, and
            image-heavy cards built for quick scanning.
          </p>
        </div>
      </section>

      <section class="toolbar" aria-label="Search and sorting controls">
        <div class="toolbar-controls">
          <div class="field">
            <label for="search" class="field-label">Search brawler</label>
            <InputGroup>
              <InputGroupInput
                id="search"
                type="search"
                placeholder="Search..."
              />
              <InputGroupAddon><Search /></InputGroupAddon>
              <InputGroupAddon align="inline-end">
                <Kbd>⌘K</Kbd>
              </InputGroupAddon>
            </InputGroup>
          </div>

          <div class="field">
            <label for="rarity-filter" class="field-label">Rarity</label>
            <NativeSelect id="rarity-filter">
              <NativeSelectOption value="all">All rarities</NativeSelectOption>
              {
                RARITY_ORDER.map((rarity) => (
                  <NativeSelectOption value={rarity}>
                    {rarity}
                    {rarityCount.has(rarity)
                      ? ` (${rarityCount.get(rarity)})`
                      : ""}
                  </NativeSelectOption>
                ))
              }
            </NativeSelect>
          </div>

          <div class="field">
            <label for="sort-order" class="field-label">Sort by</label>
            <NativeSelect id="sort-order">
              <NativeSelectOption value="rarity">Rarity</NativeSelectOption>
              <NativeSelectOption value="name-asc">Name A-Z</NativeSelectOption>
              <NativeSelectOption value="name-desc">Name Z-A</NativeSelectOption
              >
            </NativeSelect>
          </div>
        </div>

        <div class="toolbar-meta">
          <p class="results-count" data-results-count>
            Showing {brawlers.length} of {brawlers.length} brawlers
          </p>
        </div>
      </section>

      <section class="cards-section" aria-labelledby="brawler-list-title">
        <h2 id="brawler-list-title" class="sr-only">Brawler build list</h2>

        <div class="empty-state" data-empty-state hidden>
          No brawlers matched that search. Try a different name or rarity.
        </div>

        <div class="brawler-grid" data-grid>
          {brawlers.map((brawler) => <BrawlerCard brawler={brawler} />)}
        </div>
      </section>
    </main>

    <script>
      const searchInput = document.querySelector("#search");
      const raritySelect = document.querySelector("#rarity-filter");
      const sortSelect = document.querySelector("#sort-order");
      const grid = document.querySelector("[data-grid]");
      const count = document.querySelector("[data-results-count]");
      const emptyState = document.querySelector("[data-empty-state]");

      if (
        searchInput instanceof HTMLInputElement &&
        raritySelect instanceof HTMLSelectElement &&
        sortSelect instanceof HTMLSelectElement &&
        grid instanceof HTMLElement &&
        count instanceof HTMLElement &&
        emptyState instanceof HTMLElement
      ) {
        const cards = Array.from(grid.querySelectorAll("[data-card]")).filter(
          (card) => card instanceof HTMLElement,
        );
        const total = cards.length;

        const sortCards = () => {
          const sortMode = sortSelect.value;
          const sorted = [...cards].sort((left, right) => {
            const leftName = left.getAttribute("data-name") ?? "";
            const rightName = right.getAttribute("data-name") ?? "";

            if (sortMode === "name-asc") {
              return leftName.localeCompare(rightName);
            }

            if (sortMode === "name-desc") {
              return rightName.localeCompare(leftName);
            }

            const leftRank = Number(
              left.getAttribute("data-rarity-rank") ?? "0",
            );
            const rightRank = Number(
              right.getAttribute("data-rarity-rank") ?? "0",
            );

            if (leftRank !== rightRank) {
              return leftRank - rightRank;
            }

            return leftName.localeCompare(rightName);
          });

          for (const card of sorted) {
            grid.append(card);
          }
        };

        const filterCards = () => {
          const query = searchInput.value.trim().toLowerCase();
          const selectedRarity = raritySelect.value;
          let visible = 0;

          for (const card of cards) {
            const name = card.getAttribute("data-name") ?? "";
            const rarity = card.getAttribute("data-rarity") ?? "";
            const matchesQuery = query.length === 0 || name.includes(query);
            const matchesRarity =
              selectedRarity === "all" || rarity === selectedRarity;
            const isVisible = matchesQuery && matchesRarity;

            card.hidden = !isVisible;

            if (isVisible) {
              visible += 1;
            }
          }

          count.textContent = `Showing ${visible} of ${total} brawlers`;
          emptyState.hidden = visible !== 0;
        };

        const syncView = () => {
          sortCards();
          filterCards();
        };

        searchInput.addEventListener("input", filterCards);
        raritySelect.addEventListener("change", filterCards);
        sortSelect.addEventListener("change", syncView);

        syncView();
      }
    </script>
  </body>
</html>
