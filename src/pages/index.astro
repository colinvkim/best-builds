---
export const prerender = true;

import { Font } from "astro:assets";
import "../styles/site.css";
import BrawlerCard from "../components/BrawlerCard.astro";
import rawBrawlers from "../data/brawlers.json";
import { normalizeBrawlers, RARITY_ORDER } from "../lib/brawlers";
import Analytics from "@vercel/analytics/astro";

const brawlers = normalizeBrawlers(rawBrawlers).sort((left, right) => {
  if (left.rarityRank !== right.rarityRank) {
    return left.rarityRank - right.rarityRank;
  }

  return left.brawlerName.localeCompare(right.brawlerName);
});

const rarityCount = new Map<string, number>();

for (const brawler of brawlers) {
  rarityCount.set(brawler.rarity, (rarityCount.get(brawler.rarity) ?? 0) + 1);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Font cssVariable="--font-inter" />
    <title>Best Builds for Every Brawler</title>
    <meta
      name="description"
      content="Fast, searchable Brawl Stars best builds."
    />
    <meta name="theme-color" content="#f4f7fb" />
    <meta name="color-scheme" content="light" />
    <link rel="preconnect" href="https://cdn.brawlify.com" crossorigin />
    <link
      rel="preconnect"
      href="https://raw.githubusercontent.com"
      crossorigin
    />
    <link rel="dns-prefetch" href="https://cdn.brawlify.com" />
    <link rel="dns-prefetch" href="https://raw.githubusercontent.com" />
    <Analytics />
  </head>

  <body>
    <main class="page-shell">
      <section class="hero-panel" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="hero-kicker">Brawl Stars Build Index</p>
          <h1 id="page-title" class="hero-title">
            Best setup for every brawler, sorted for speed.
          </h1>
          <p class="hero-copy-text">
            Quickly discover the best builds of brawlers. The UI stays simple on
            purpose: fast search, predictable sorting, no animation, and cards
            built for quick scanning.
          </p>
        </div>
      </section>

      <section class="toolbar" aria-label="Search and sorting controls">
        <div class="toolbar-controls">
          <div class="field">
            <label for="search" class="field-label">Search brawler</label>
            <div class="field-control-wrap">
              <input
                id="search"
                class="field-control search-input"
                type="search"
                inputmode="search"
                enterkeyhint="search"
                autocomplete="off"
                spellcheck="false"
                placeholder="Search..."
              />
              <svg
                class="search-icon"
                viewBox="0 0 24 24"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="11" cy="11" r="7"></circle>
                <path d="m20 20-3.5-3.5"></path>
              </svg>
              <span class="shortcut-hint" data-shortcut-hint hidden></span>
            </div>
          </div>

          <div class="field">
            <label for="rarity-filter" class="field-label">Rarity</label>
            <div class="field-control-wrap">
              <select id="rarity-filter" class="field-control select-control">
                <option value="all">All rarities</option>
                {
                  RARITY_ORDER.map((rarity) => (
                    <option value={rarity}>
                      {rarity}
                      {rarityCount.has(rarity)
                        ? ` (${rarityCount.get(rarity)})`
                        : ""}
                    </option>
                  ))
                }
              </select>
              <svg
                class="select-caret"
                viewBox="0 0 10 6"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 1 5 5 9 1"></path>
              </svg>
            </div>
          </div>

          <div class="field">
            <label for="sort-order" class="field-label">Sort by</label>
            <div class="field-control-wrap">
              <select id="sort-order" class="field-control select-control">
                <option value="rarity">Rarity</option>
                <option value="name-asc">Name A-Z</option>
                <option value="name-desc">Name Z-A</option>
              </select>
              <svg
                class="select-caret"
                viewBox="0 0 10 6"
                aria-hidden="true"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 1 5 5 9 1"></path>
              </svg>
            </div>
          </div>
        </div>

        <div class="toolbar-meta">
          <p class="results-count" data-results-count>
            Showing {brawlers.length} of {brawlers.length} brawlers
          </p>
        </div>
      </section>

      <section class="cards-section" aria-labelledby="brawler-list-title">
        <h2 id="brawler-list-title" class="sr-only">Brawler build list</h2>

        <div class="empty-state" data-empty-state hidden>
          No brawlers matched that search. Try a different name or rarity.
        </div>

        <div class="brawler-grid" data-grid>
          {
            brawlers.map((brawler, index) => (
              <BrawlerCard brawler={brawler} eager={index < 4} />
            ))
          }
        </div>
      </section>
    </main>

    <script>
      const searchInput = document.querySelector("#search");
      const raritySelect = document.querySelector("#rarity-filter");
      const sortSelect = document.querySelector("#sort-order");
      const grid = document.querySelector("[data-grid]");
      const count = document.querySelector("[data-results-count]");
      const emptyState = document.querySelector("[data-empty-state]");
      const shortcutHint = document.querySelector("[data-shortcut-hint]");

      const getPlatformShortcut = () => {
        const userAgent = navigator.userAgent?.toLowerCase();

        if (userAgent.includes("android") || userAgent.includes("iphone")) {
          return "";
        }

        if (userAgent.includes("ipad") || userAgent.includes("mac")) {
          return "⌘K";
        }

        if (
          userAgent.includes("windows") ||
          userAgent.includes("linux") ||
          userAgent.includes("x11")
        ) {
          return "Ctrl + K";
        }

        return "";
      };

      if (shortcutHint instanceof HTMLElement) {
        const shortcutLabel = getPlatformShortcut();

        shortcutHint.textContent = shortcutLabel;
        shortcutHint.hidden = shortcutLabel.length === 0;
      }

      if (
        searchInput instanceof HTMLInputElement &&
        raritySelect instanceof HTMLSelectElement &&
        sortSelect instanceof HTMLSelectElement &&
        grid instanceof HTMLElement &&
        count instanceof HTMLElement &&
        emptyState instanceof HTMLElement
      ) {
        const cards = Array.from(grid.children).filter(
          (card) => card instanceof HTMLElement,
        );
        const total = cards.length;
        const collator = new Intl.Collator(undefined, {
          sensitivity: "base",
        });

        const readCardData = (card: HTMLElement) => ({
          name: card.dataset.name ?? "",
          rarity: card.dataset.rarity ?? "",
          rarityRank: Number(card.dataset.rarityRank ?? "0"),
        });

        const applyFilters = () => {
          const query = searchInput.value.trim().toLowerCase();
          const selectedRarity = raritySelect.value;
          let visible = 0;

          for (const card of cards) {
            const data = readCardData(card);
            const matchesQuery =
              query.length === 0 || data.name.includes(query);
            const matchesRarity =
              selectedRarity === "all" || data.rarity === selectedRarity;
            const isVisible = matchesQuery && matchesRarity;

            card.hidden = !isVisible;

            if (isVisible) {
              visible += 1;
            }
          }

          count.textContent = `Showing ${visible} of ${total} brawlers`;
          emptyState.hidden = visible !== 0;
        };

        const sortCards = () => {
          const sortMode = sortSelect.value;
          const sorted = [...cards].sort((left, right) => {
            const leftData = readCardData(left);
            const rightData = readCardData(right);

            if (sortMode === "name-asc") {
              return collator.compare(leftData.name, rightData.name);
            }

            if (sortMode === "name-desc") {
              return collator.compare(rightData.name, leftData.name);
            }

            if (leftData.rarityRank !== rightData.rarityRank) {
              return leftData.rarityRank - rightData.rarityRank;
            }

            return collator.compare(leftData.name, rightData.name);
          });

          for (const card of sorted) {
            grid.append(card);
          }
        };

        searchInput.addEventListener("input", applyFilters, { passive: true });
        raritySelect.addEventListener("change", applyFilters);
        sortSelect.addEventListener("change", () => {
          sortCards();
          applyFilters();
        });

        applyFilters();
      }

      window.addEventListener("keydown", (event) => {
        if (
          (event.metaKey || event.ctrlKey) &&
          event.key.toLowerCase() === "k"
        ) {
          event.preventDefault();
          document.getElementById("search")?.focus();
        }
      });
    </script>
  </body>
</html>
