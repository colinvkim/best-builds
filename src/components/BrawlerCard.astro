---
import { Image } from "astro:assets";
import { RARITY_STYLES, type Brawler } from "../lib/brawlers";
import { Badge } from "@/components/ui/badge"

type Props = {
  brawler: Brawler;
};

const { brawler } = Astro.props;
const rarityStyle = RARITY_STYLES[brawler.rarity];
---

<article
  class="brawler-card"
  data-card
  data-name={brawler.brawlerName.toLowerCase()}
  data-rarity={brawler.rarity}
  data-rarity-rank={String(brawler.rarityRank)}
>
  <header class="card-header">
    <img
      class="brawler-icon"
      src={brawler.brawlerIconUrl}
      alt={`${brawler.brawlerName} icon`}
      width="96"
      height="96"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />

    <div class="title-wrap">
      <p class="eyebrow">Best Build</p>
      <h2 class="card-title">{brawler.brawlerName}</h2>
      <Badge style={{ backgroundColor: rarityStyle.color, color: rarityStyle.textColor }}>
        {brawler.rarity}
      </Badge>
    </div>
  </header>

  <dl class="build-list">
    <div class="build-row">
      <dt class="build-term">
        <span>Gadget</span>
        {
          brawler.gadgetChoices.length > 1 && (
            <span class="build-note">Default + niche</span>
          )
        }
      </dt>
      <dd class="build-detail build-detail--stack">
        {
          brawler.gadgetChoices.map((gadget, index) =>
            index === 0 ? (
              <span class="build-choice build-choice--primary">
                {
                  brawler.gadgetChoices.length > 1 && (
                    <span class="choice-label">Safe Default</span>
                  )
                }
                <span class="build-choice-content">
                  <img
                    src={gadget.iconUrl}
                    alt={`${gadget.name} icon`}
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
                  <span class="build-copy">{gadget.name}</span>
                </span>
              </span>
            ) : (
              <span class="build-choice build-choice--secondary">
                <span class="choice-label">Niche Pick</span>
                <span class="build-choice-content">
                  <img
                    src={gadget.iconUrl}
                    alt={`${gadget.name} icon`}
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
                  <span class="build-copy">{gadget.name}</span>
                </span>
              </span>
            )
          )
        }
      </dd>
    </div>

    <div class="build-row">
      <dt class="build-term">
        <span>Star Power</span>
        {
          brawler.alternativeStarPowerChoices.length > 0 && (
            <span class="build-note">Default + niche</span>
          )
        }
      </dt>
      <dd class="build-detail build-detail--stack">
        <span class="build-choice build-choice--primary">
          {
            brawler.alternativeStarPowerChoices.length > 0 && (
              <span class="choice-label">Safe Default</span>
            )
          }
          <span class="build-choice-content">
            <img
              src={brawler.bestStarPowerIconUrl}
              alt={`${brawler.bestStarPowerName} icon`}
              width="48"
              height="48"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
            />
            <span class="build-copy">{brawler.bestStarPowerName}</span>
          </span>
        </span>
        {
          brawler.alternativeStarPowerChoices.map((starPower) => (
            <span class="build-choice build-choice--secondary">
              <span class="choice-label">Niche Pick</span>
              <span class="build-choice-content">
                <img
                  src={starPower.iconUrl}
                  alt={`${starPower.name} icon`}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                />
                <span class="build-copy">{starPower.name}</span>
              </span>
            </span>
          ))
        }
      </dd>
    </div>

    <div class="build-row">
      <dt class="build-term">
        <span>Gears</span>
        {
          brawler.alternativeGearChoices.length > 0 && (
            <span class="build-note">Default + flex</span>
          )
        }
      </dt>
      <dd class="build-detail build-detail--stack">
        <div class="gear-group">
          <span class="choice-label">Default Pair</span>
          <div class="build-detail gear-list">
            {
              brawler.bestGearChoices.map((gear) => (
                <span class="gear-chip" tabindex="0" aria-label={gear.name}>
                  <Image
                    class="gear-icon"
                    src={gear.image}
                    alt={`${gear.name} gear icon`}
                    layout="constrained"
                    loading="lazy"
                  />
                  <span class="gear-tooltip" aria-hidden="true">{gear.name}</span>
                </span>
              ))
            }
          </div>
        </div>
        {
          brawler.alternativeGearChoices.length > 0 && (
            <div class="gear-group gear-group--secondary">
              <span class="choice-label">Niche Swaps</span>
              <div class="build-detail gear-list">
                {
                  brawler.alternativeGearChoices.map((gear) => (
                    <span class="gear-chip gear-chip--secondary" tabindex="0" aria-label={gear.name}>
                      <Image
                        class="gear-icon"
                        src={gear.image}
                        alt={`${gear.name} gear icon`}
                        layout="constrained"
                        loading="lazy"
                      />
                      <span class="gear-tooltip" aria-hidden="true">{gear.name}</span>
                    </span>
                  ))
                }
              </div>
            </div>
          )
        }
      </dd>
    </div>
  </dl>
</article>
