---
import { RARITY_STYLES, type Brawler } from "../lib/brawlers";

type Props = {
  brawler: Brawler;
  eager?: boolean;
};

const { brawler, eager = false } = Astro.props;
const rarityStyle = RARITY_STYLES[brawler.rarity];
---

<article
  class="brawler-card"
  data-card
  data-name={brawler.brawlerName.toLowerCase()}
  data-rarity={brawler.rarity}
  data-rarity-rank={String(brawler.rarityRank)}
>
  <header class="card-header">
    <img
      class="brawler-icon"
      src={brawler.brawlerIconUrl}
      alt={`${brawler.brawlerName} icon`}
      width="96"
      height="96"
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={eager ? "high" : "low"}
    />

    <div class="title-wrap">
      <p class="eyebrow">Best Build</p>
      <h2 class="card-title">{brawler.brawlerName}</h2>
      <span
        class="rarity-pill"
        style={`--rarity-bg:${rarityStyle.color};--rarity-text:${rarityStyle.textColor};`}
      >
        {brawler.rarity}
      </span>
    </div>
  </header>

  <div class="build-list">
    <section class="build-row" aria-label="Gadget choices">
      <div class="build-label">
        <span class="build-term">Gadget</span>
        {
          brawler.gadgetChoices.length > 1 && (
            <span class="build-note">Default + niche</span>
          )
        }
      </div>
      <div class="choice-list">
        {
          brawler.gadgetChoices.map((gadget, index) => (
            <div
              class:list={[
                "build-choice",
                index === 0 ? "build-choice--primary" : null,
              ]}
            >
              {brawler.gadgetChoices.length > 1 && (
                <span class="choice-label">
                  {index === 0 ? "Safe Default" : "Niche Pick"}
                </span>
              )}
              <div class="build-choice-content">
                <img
                  class="ability-icon"
                  src={gadget.iconUrl}
                  alt=""
                  width="48"
                  height="48"
                  loading={eager ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={eager ? "high" : "low"}
                />
                <span class="build-copy">{gadget.name}</span>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="build-row" aria-label="Star power choices">
      <div class="build-label">
        <span class="build-term">Star Power</span>
        {
          brawler.alternativeStarPowerChoice && (
            <span class="build-note">Default + niche</span>
          )
        }
      </div>
      <div class="choice-list">
        <div class="build-choice build-choice--primary">
          {
            brawler.alternativeStarPowerChoice && (
              <span class="choice-label">Safe Default</span>
            )
          }
          <div class="build-choice-content">
            <img
              class="ability-icon"
              src={brawler.bestStarPowerIconUrl}
              alt=""
              width="48"
              height="48"
              loading={eager ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={eager ? "high" : "low"}
            />
            <span class="build-copy">{brawler.bestStarPowerName}</span>
          </div>
        </div>
        {
          brawler.alternativeStarPowerChoice && (
            <div class="build-choice">
              <span class="choice-label">Niche Pick</span>
              <div class="build-choice-content">
                <img
                  class="ability-icon"
                  src={brawler.alternativeStarPowerChoice.iconUrl}
                  alt=""
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                />
                <span class="build-copy">
                  {brawler.alternativeStarPowerChoice.name}
                </span>
              </div>
            </div>
          )
        }
      </div>
    </section>

    <section class="build-row" aria-label="Gear choices">
      <div class="build-label">
        <span class="build-term">Gears</span>
      </div>
      <div class="choice-list">
        <div class="build-choice">
          <span class="choice-label">Safe Default</span>
          <div class="gear-list">
            {
              brawler.bestGearChoices.map((gear) => (
                <span
                  class="gear-chip"
                  title={gear.name}
                  aria-label={gear.name}
                >
                  <img
                    class="gear-icon"
                    src={gear.image.src}
                    alt=""
                    width={gear.image.width}
                    height={gear.image.height}
                    loading="lazy"
                    decoding="async"
                  />
                </span>
              ))
            }
          </div>
        </div>
        {
          brawler.alternativeGearChoices.length > 0 && (
            <div class="build-choice">
              <span class="choice-label">Useful Swaps</span>
              <div class="gear-list">
                {brawler.alternativeGearChoices.map((gear) => (
                  <span
                    class="gear-chip gear-chip--secondary"
                    title={gear.name}
                    aria-label={gear.name}
                  >
                    <img
                      class="gear-icon"
                      src={gear.image.src}
                      alt=""
                      width={gear.image.width}
                      height={gear.image.height}
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </section>
  </div>
</article>
