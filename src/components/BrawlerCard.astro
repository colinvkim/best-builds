---
import { Image } from "astro:assets";
import { RARITY_STYLES, type Brawler } from "../lib/brawlers";
import { Badge } from "@/components/ui/badge"

type Props = {
  brawler: Brawler;
};

const { brawler } = Astro.props;
const rarityStyle = RARITY_STYLES[brawler.rarity];
---

<article
  class="brawler-card"
  data-card
  data-name={brawler.brawlerName.toLowerCase()}
  data-rarity={brawler.rarity}
  data-rarity-rank={String(brawler.rarityRank)}
>
  <header class="card-header">
    <img
      class="brawler-icon"
      src={brawler.brawlerIconUrl}
      alt={`${brawler.brawlerName} icon`}
      width="96"
      height="96"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    />

    <div class="title-wrap">
      <p class="eyebrow">Best Build</p>
      <h2 class="card-title">{brawler.brawlerName}</h2>
      <Badge style={{ backgroundColor: rarityStyle.color, color: rarityStyle.textColor }}>
        {brawler.rarity}
      </Badge>
    </div>
  </header>

  <dl class="build-list">
    <div class="build-row">
      <dt class="build-term">
        <span>{brawler.gadgetChoices.length > 1 ? "Gadgets" : "Gadget"}</span>
        {
          brawler.gadgetChoices.length > 1 && (
            <span class="build-note">Both viable</span>
          )
        }
      </dt>
      <dd class:list={["build-detail", { "build-choice-list": brawler.gadgetChoices.length > 1 }]}>
        {
          brawler.gadgetChoices.map((gadget, index) => (
            <>
              <span class:list={["build-choice", { "build-choice--multi": brawler.gadgetChoices.length > 1 }]}>
                <img
                  src={gadget.iconUrl}
                  alt={`${gadget.name} icon`}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                />
                <span class="build-copy">{gadget.name}</span>
              </span>
              {
                index < brawler.gadgetChoices.length - 1 && (
                  <span class="build-divider" aria-hidden="true">or</span>
                )
              }
            </>
          ))
        }
      </dd>
    </div>

    <div class="build-row">
      <dt class="build-term">Star Power</dt>
      <dd class="build-detail">
        <img
          src={brawler.bestStarPowerIconUrl}
          alt={`${brawler.bestStarPowerName} icon`}
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
        <span class="build-copy">{brawler.bestStarPowerName}</span>
      </dd>
    </div>

    <div class="build-row">
      <dt class="build-term">Gears</dt>
      <dd class="build-detail gear-list">
        {
          brawler.best2Gears.map((gear, index) => (
            <span class="gear-chip" tabindex="0" aria-label={gear}>
              <Image
                class="gear-icon"
                src={brawler.best2GearsImage[index]}
                alt={`${gear} gear icon`}
                layout="constrained"
                loading="lazy"
              />
              <span class="gear-tooltip" aria-hidden="true">{gear}</span>
            </span>
          ))
        }
      </dd>
    </div>
  </dl>
</article>
